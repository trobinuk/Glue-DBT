        <mxCell id="U3xCyMBUVf51coK3sNU9-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;rounded=0;gradientColor=#ffd966;" value="&lt;b&gt;models/mart:&lt;/b&gt;&lt;div&gt;mart.yml&lt;/div&gt;&lt;div&gt;country_details_asia.sql&lt;/div&gt;&lt;div&gt;country_details_europe.sql etc (7 files in total, for each table 1 file)&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="343" x="857" y="529" as="geometry" />
        </mxCell>
        <mxCell id="U3xCyMBUVf51coK3sNU9-10" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;rounded=0;gradientColor=#ffd966;" value="&lt;b&gt;mart.yml:&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1. models: Write the unit tests not_null, unique, accepted_values (7 models inside a single .yml file)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;2. each table will need a sql file (so 7 files)&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="310" x="857" y="604" as="geometry" />
        </mxCell>
        <mxCell id="U3xCyMBUVf51coK3sNU9-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;rounded=0;gradientColor=#ffd966;" value="&lt;b&gt;country_details_asia.sql:&lt;/b&gt;&lt;div&gt;1. Config: materialized = table&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2. schema_name: mart (macro generate_schema_name)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;&lt;i&gt;After config:&lt;/i&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;3.&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;using CTE named as &#39;country_details_asia&#39; read from table (&lt;/span&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;{{ ref(&#39;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;country_details_transform&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;&#39;)}}&lt;/b&gt; ) &amp;amp; filter and dbt automatically creates table and insert those records.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="330" x="857" y="669" as="geometry" />
        </mxCell>
