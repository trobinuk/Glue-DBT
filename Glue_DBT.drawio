        <mxCell id="U3xCyMBUVf51coK3sNU9-17" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=#fff2cc;align=left;verticalAlign=middle;rounded=0;gradientColor=#ffd966;" value="&lt;b&gt;country_details_raw.sql:&lt;/b&gt;&lt;div&gt;1. Config: materialized = table&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2. schema_name: transform (macro)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;u&gt;&lt;i&gt;After config:&lt;/i&gt;&lt;/u&gt;&lt;/div&gt;&lt;div&gt;3. using CTE named as &#39;country_details_transform&#39; read from table (&lt;b&gt;{{ ref(&#39;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;country_details_raw&lt;/span&gt;&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;b&gt;&#39;)}}&lt;/b&gt; ) and dbt automatically creates table and insert those records.&lt;/span&gt;&lt;/div&gt;" vertex="1">
